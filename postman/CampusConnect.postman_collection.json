{
  "info": {
    "name": "CampusConnect API",
    "description": "Private social networking platform for colleges",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api/v1" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "userId", "value": "" },
    { "key": "postId", "value": "" },
    { "key": "conversationId", "value": "" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": "{{baseUrl}}/health"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "if (pm.response.code === 201) {",
                "  const res = pm.response.json();",
                "  pm.collectionVariables.set('accessToken', res.data.accessToken);",
                "  pm.collectionVariables.set('refreshToken', res.data.refreshToken);",
                "  pm.collectionVariables.set('userId', res.data.user._id);",
                "}"
              ]
            }
          }],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test Student\",\n  \"email\": \"test@student.campusconnect.edu\",\n  \"password\": \"Student@123\",\n  \"role\": \"student\",\n  \"department\": \"Computer Science\",\n  \"batch\": \"2025\"\n}"
            },
            "url": "{{baseUrl}}/auth/register"
          }
        },
        {
          "name": "Login",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "if (pm.response.code === 200) {",
                "  const res = pm.response.json();",
                "  pm.collectionVariables.set('accessToken', res.data.accessToken);",
                "  pm.collectionVariables.set('refreshToken', res.data.refreshToken);",
                "  pm.collectionVariables.set('userId', res.data.user._id);",
                "}"
              ]
            }
          }],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"alice.williams@student.campusconnect.edu\",\n  \"password\": \"Student@123\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/refresh-token"
          }
        },
        {
          "name": "Get Current User",
          "request": { "method": "GET", "url": "{{baseUrl}}/auth/me" }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentPassword\": \"Student@123\",\n  \"newPassword\": \"NewPass@123\"\n}"
            },
            "url": "{{baseUrl}}/auth/change-password"
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"alice.williams@student.campusconnect.edu\"\n}"
            },
            "url": "{{baseUrl}}/auth/forgot-password"
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"RESET_TOKEN_HERE\",\n  \"password\": \"NewPass@123\"\n}"
            },
            "url": "{{baseUrl}}/auth/reset-password"
          }
        },
        {
          "name": "Logout",
          "request": { "method": "POST", "url": "{{baseUrl}}/auth/logout" }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Search Users",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/users/search?search=alice&role=student&department=Computer Science&page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["users", "search"],
              "query": [
                { "key": "search", "value": "alice" },
                { "key": "role", "value": "student" },
                { "key": "department", "value": "Computer Science" },
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Get User by ID",
          "request": { "method": "GET", "url": "{{baseUrl}}/users/{{userId}}" }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bio\": \"Updated bio\",\n  \"skills\": [\"JavaScript\", \"TypeScript\", \"Node.js\"]\n}"
            },
            "url": "{{baseUrl}}/users/profile"
          }
        }
      ]
    },
    {
      "name": "Posts",
      "item": [
        {
          "name": "Create Post",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "if (pm.response.code === 201) {",
                "  pm.collectionVariables.set('postId', pm.response.json().data._id);",
                "}"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"Hello CampusConnect! This is my first post.\",\n  \"tags\": [\"introduction\", \"college\"]\n}"
            },
            "url": "{{baseUrl}}/posts"
          }
        },
        {
          "name": "Get Feed",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/posts/feed?sort=latest&page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["posts", "feed"],
              "query": [
                { "key": "sort", "value": "latest" },
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Get Trending Posts",
          "request": { "method": "GET", "url": "{{baseUrl}}/posts/trending?limit=10" }
        },
        {
          "name": "Update Post",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"Updated post content\"\n}"
            },
            "url": "{{baseUrl}}/posts/{{postId}}"
          }
        },
        {
          "name": "Like Post",
          "request": { "method": "POST", "url": "{{baseUrl}}/posts/{{postId}}/like" }
        },
        {
          "name": "Unlike Post",
          "request": { "method": "DELETE", "url": "{{baseUrl}}/posts/{{postId}}/like" }
        },
        {
          "name": "Delete Post",
          "request": { "method": "DELETE", "url": "{{baseUrl}}/posts/{{postId}}" }
        }
      ]
    },
    {
      "name": "Comments",
      "item": [
        {
          "name": "Add Comment",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"Great post!\"\n}"
            },
            "url": "{{baseUrl}}/comments/{{postId}}"
          }
        },
        {
          "name": "Get Comments",
          "request": { "method": "GET", "url": "{{baseUrl}}/comments/{{postId}}?page=1&limit=10" }
        },
        {
          "name": "Delete Comment",
          "request": { "method": "DELETE", "url": "{{baseUrl}}/comments/COMMENT_ID" }
        }
      ]
    },
    {
      "name": "Connections",
      "item": [
        {
          "name": "Send Connection Request",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"receiverId\": \"USER_ID_HERE\"\n}"
            },
            "url": "{{baseUrl}}/connections/request"
          }
        },
        {
          "name": "Get Connections",
          "request": { "method": "GET", "url": "{{baseUrl}}/connections?page=1&limit=10" }
        },
        {
          "name": "Get Pending Requests",
          "request": { "method": "GET", "url": "{{baseUrl}}/connections/pending?page=1&limit=10" }
        },
        {
          "name": "Accept Request",
          "request": { "method": "PUT", "url": "{{baseUrl}}/connections/CONNECTION_ID/accept" }
        },
        {
          "name": "Reject Request",
          "request": { "method": "PUT", "url": "{{baseUrl}}/connections/CONNECTION_ID/reject" }
        },
        {
          "name": "Cancel Request",
          "request": { "method": "DELETE", "url": "{{baseUrl}}/connections/CONNECTION_ID/cancel" }
        },
        {
          "name": "Remove Connection",
          "request": { "method": "DELETE", "url": "{{baseUrl}}/connections/CONNECTION_ID" }
        }
      ]
    },
    {
      "name": "Opportunities",
      "item": [
        {
          "name": "Create Opportunity",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Frontend Developer Intern\",\n  \"description\": \"Looking for a passionate frontend developer intern.\",\n  \"company\": \"TechCorp\",\n  \"type\": \"internship\",\n  \"skills\": [\"React\", \"TypeScript\"],\n  \"applyLink\": \"https://techcorp.com/careers\",\n  \"deadline\": \"2026-08-01T00:00:00.000Z\"\n}"
            },
            "url": "{{baseUrl}}/opportunities"
          }
        },
        {
          "name": "Search Opportunities",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/opportunities/search?type=internship&page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["opportunities", "search"],
              "query": [
                { "key": "type", "value": "internship" },
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Get Opportunity",
          "request": { "method": "GET", "url": "{{baseUrl}}/opportunities/OPPORTUNITY_ID" }
        },
        {
          "name": "Update Opportunity",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"title\": \"Updated Title\"\n}" },
            "url": "{{baseUrl}}/opportunities/OPPORTUNITY_ID"
          }
        },
        {
          "name": "Delete Opportunity",
          "request": { "method": "DELETE", "url": "{{baseUrl}}/opportunities/OPPORTUNITY_ID" }
        }
      ]
    },
    {
      "name": "Events",
      "item": [
        {
          "name": "Create Event",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Coding Workshop\",\n  \"description\": \"Learn competitive programming basics.\",\n  \"location\": \"Lab 301\",\n  \"eventDate\": \"2026-07-25T10:00:00.000Z\"\n}"
            },
            "url": "{{baseUrl}}/events"
          }
        },
        {
          "name": "Get All Events",
          "request": { "method": "GET", "url": "{{baseUrl}}/events?page=1&limit=10" }
        },
        {
          "name": "Get Event",
          "request": { "method": "GET", "url": "{{baseUrl}}/events/EVENT_ID" }
        },
        {
          "name": "RSVP Interested",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"interested\"\n}" },
            "url": "{{baseUrl}}/events/EVENT_ID/rsvp"
          }
        },
        {
          "name": "RSVP Going",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"going\"\n}" },
            "url": "{{baseUrl}}/events/EVENT_ID/rsvp"
          }
        },
        {
          "name": "Delete Event",
          "request": { "method": "DELETE", "url": "{{baseUrl}}/events/EVENT_ID" }
        }
      ]
    },
    {
      "name": "Messages",
      "item": [
        {
          "name": "Create Conversation",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "if (pm.response.code === 201) {",
                "  pm.collectionVariables.set('conversationId', pm.response.json().data._id);",
                "}"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"participantId\": \"USER_ID_HERE\"\n}"
            },
            "url": "{{baseUrl}}/messages/conversations"
          }
        },
        {
          "name": "Get Conversations",
          "request": { "method": "GET", "url": "{{baseUrl}}/messages/conversations?page=1&limit=10" }
        },
        {
          "name": "Send Message",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"text\": \"Hello! How are you?\"\n}"
            },
            "url": "{{baseUrl}}/messages/{{conversationId}}"
          }
        },
        {
          "name": "Get Messages",
          "request": { "method": "GET", "url": "{{baseUrl}}/messages/{{conversationId}}?page=1&limit=20" }
        },
        {
          "name": "Mark as Read",
          "request": { "method": "PUT", "url": "{{baseUrl}}/messages/{{conversationId}}/read" }
        }
      ]
    },
    {
      "name": "Feed",
      "item": [
        {
          "name": "Get Unified Feed",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/feed?sort=latest&page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["feed"],
              "query": [
                { "key": "sort", "value": "latest" },
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Notifications",
      "item": [
        {
          "name": "Get Notifications",
          "request": { "method": "GET", "url": "{{baseUrl}}/notifications?page=1&limit=20" }
        },
        {
          "name": "Mark as Read",
          "request": { "method": "PUT", "url": "{{baseUrl}}/notifications/NOTIFICATION_ID/read" }
        },
        {
          "name": "Mark All as Read",
          "request": { "method": "PUT", "url": "{{baseUrl}}/notifications/read-all" }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Get All Users",
          "request": { "method": "GET", "url": "{{baseUrl}}/admin/users?page=1&limit=20" }
        },
        {
          "name": "Get Analytics",
          "request": { "method": "GET", "url": "{{baseUrl}}/admin/analytics" }
        },
        {
          "name": "Block User",
          "request": { "method": "PUT", "url": "{{baseUrl}}/admin/users/USER_ID/block" }
        },
        {
          "name": "Unblock User",
          "request": { "method": "PUT", "url": "{{baseUrl}}/admin/users/USER_ID/unblock" }
        },
        {
          "name": "Delete User",
          "request": { "method": "DELETE", "url": "{{baseUrl}}/admin/users/USER_ID" }
        },
        {
          "name": "Delete Post (Admin)",
          "request": { "method": "DELETE", "url": "{{baseUrl}}/admin/posts/{{postId}}" }
        },
        {
          "name": "Delete Opportunity (Admin)",
          "request": { "method": "DELETE", "url": "{{baseUrl}}/admin/opportunities/OPPORTUNITY_ID" }
        }
      ]
    }
  ]
}
